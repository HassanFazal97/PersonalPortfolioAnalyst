# =============================================================================
# Cirvia — environment variables
# Copy to .env and fill in values. All keys are read via app/config.py.
# Generate API token: python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# --- Required (API won't start usefully without these) -----------------------

ANTHROPIC_API_KEY=
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/cirvia
API_TOKEN=                        # long random string; owner/service auth

# --- Database (optional overrides) -------------------------------------------

# Owner/privileged connection for migrations when DATABASE_URL is a restricted role.
# MIGRATION_DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<pw>@...
# Supabase session pooler (IPv4):
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
DB_SSL=false                        # set true for Supabase / managed Postgres

# --- Web app sign-in (/app, /app/onboarding, /app/dashboard) -----------------
# Required for the in-browser product UI. Without these, /app returns 503.

SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=                  # publishable key (sb_publishable_…)
# JWT verification — new projects use asymmetric JWKS from SUPABASE_URL (default).
# Legacy HS256 fallback only (older projects):
# SUPABASE_JWT_SECRET=
# SUPABASE_JWT_AUD=authenticated    # default; rarely needs changing

# --- Single-user / owner mode (optional) -------------------------------------
# When Supabase is unset, only API_TOKEN auth works (scripts, curl, cron).
# DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# --- AI models ---------------------------------------------------------------

MODEL=claude-sonnet-4-6
CLASSIFIER_MODEL=claude-haiku-4-5   # news signal tagging
MACRO_MODEL=claude-sonnet-4-6       # macro specialists (web search)

# --- Run budgets (USD caps per chat/digest/macro run) ------------------------

CHAT_MAX_ITERATIONS=10
CHAT_MAX_COST_USD=0.50
DIGEST_MAX_ITERATIONS=25
DIGEST_MAX_COST_USD=1.50
MACRO_MAX_ITERATIONS=30
MACRO_MAX_COST_USD=2.00
MAX_TOOL_OUTPUT_TOKENS=6000
TOOL_TIMEOUT_SECONDS=10

# --- Plan gating (Free vs Pro limits) ----------------------------------------

FREE_MONTHLY_COST_CAP_USD=0.75
PRO_MONTHLY_COST_CAP_USD=6.00
FREE_DAILY_CHAT_LIMIT=5
FREE_MAX_DIGEST_HOLDINGS=3          # watchlist cap on Free tier

# --- Scheduling --------------------------------------------------------------

DIGEST_CRON=45 7 * * 1-5            # weekday morning digest (America/Toronto)
TZ=America/Toronto
MACRO_SCAN_INTERVAL_MINUTES=0         # set e.g. 60 to enable in-process macro scans

# --- News (optional — yfinance fallback if empty) ----------------------------

FINNHUB_API_KEY=

# --- SnapTrade (Wealthsimple sync) — https://dashboard.snaptrade.com --------

SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
# Personal dashboard keys: leave USER_ID/SECRET empty (auto mode, owner only).
# Commercial keys: per-user secrets stored encrypted in DB.
SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=
SNAPTRADE_AUTH_MODE=auto            # auto | personal | commercial
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BROKER_SECRETS_KEY=

# --- Multi-channel delivery (optional) ---------------------------------------
# Dispatcher drains outbound_messages every N seconds. 0 disables it.

DELIVERY_INTERVAL_SECONDS=30
DELIVERY_MAX_ATTEMPTS=5
PUBLIC_BASE_URL=                    # e.g. https://app.example.com — Twilio webhooks

# Twilio SMS (all three required for the sms channel)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=                   # E.164, e.g. +14165550100
# Point inbound SMS webhook at $PUBLIC_BASE_URL/webhooks/twilio/sms

# Resend email (both required for the email channel)
RESEND_API_KEY=
EMAIL_FROM=                           # e.g. "Cirvia <digest@yourdomain.com>"
# HMAC key for signed email unsubscribe links (CASL). Long random string;
# falls back to API_TOKEN when unset.
UNSUBSCRIBE_SECRET=

# Discord uses per-user webhook URLs (no env vars). Configure in /app onboarding.
