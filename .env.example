ANTHROPIC_API_KEY=
FINNHUB_API_KEY=
DATABASE_URL=postgresql+asyncpg://...
# Owner connection for migrations when DATABASE_URL is a restricted role:
# MIGRATION_DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<pw>@...
# Supabase (Session pooler, IPv4): postgresql+asyncpg://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
DB_SSL=false                    # set true for Supabase / managed Postgres
API_TOKEN=                      # long random string
# Multi-user auth (optional — leave unset for single-user mode)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=              # publishable key — powers /app sign-in pages
# SUPABASE_JWT_SECRET=          # legacy HS256 fallback only
MODEL=claude-sonnet-4-6
CLASSIFIER_MODEL=claude-haiku-4-5
MACRO_MODEL=claude-sonnet-4-6
MACRO_SCAN_INTERVAL_MINUTES=0   # set e.g. 60 to enable in-process macro scans
MACRO_MAX_ITERATIONS=30
MACRO_MAX_COST_USD=2.00
CHAT_MAX_ITERATIONS=10
CHAT_MAX_COST_USD=0.50
DIGEST_MAX_ITERATIONS=25
DIGEST_MAX_COST_USD=1.50
MAX_TOOL_OUTPUT_TOKENS=6000
DIGEST_CRON=45 7 * * 1-5
TZ=America/Toronto

# SnapTrade (Wealthsimple sync) — https://dashboard.snaptrade.com
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
# Personal dashboard keys: leave USER_ID/SECRET empty (auto mode, owner only).
# Commercial keys: per-user secrets stored encrypted in DB (BROKER_SECRETS_KEY).
SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=
SNAPTRADE_AUTH_MODE=auto
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BROKER_SECRETS_KEY=
