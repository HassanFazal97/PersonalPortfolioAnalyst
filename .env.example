# =============================================================================
# Cirvia — environment variables
# Copy to .env and fill in values. All keys are read via app/config.py.
# Generate API token: python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# --- Required (API won't start usefully without these) -----------------------

ANTHROPIC_API_KEY=
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/cirvia
API_TOKEN=                        # long random string; owner/service auth

# --- Database (optional overrides) -------------------------------------------

# Owner/privileged connection for migrations when DATABASE_URL is a restricted role.
# MIGRATION_DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<pw>@...
# Supabase session pooler (IPv4):
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
DB_SSL=false                        # set true for Supabase / managed Postgres

# --- Web app sign-in (/app, /app/onboarding, /app/dashboard) -----------------
# Required for the in-browser product UI. Without these, /app returns 503.

SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=                  # publishable key (sb_publishable_…)
# JWT verification — new projects use asymmetric JWKS from SUPABASE_URL (default).
# Legacy HS256 fallback only (older projects):
# SUPABASE_JWT_SECRET=
# SUPABASE_JWT_AUD=authenticated    # default; rarely needs changing

# --- Single-user / owner mode (optional) -------------------------------------
# When Supabase is unset, only API_TOKEN auth works (scripts, curl, cron).
# DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# --- AI models ---------------------------------------------------------------

MODEL=claude-sonnet-4-6
CLASSIFIER_MODEL=claude-haiku-4-5   # news signal tagging
MACRO_MODEL=claude-sonnet-4-6       # macro specialists (web search)

# --- Run budgets (USD caps per chat/digest/macro run) ------------------------

CHAT_MAX_ITERATIONS=10
CHAT_HISTORY_TURNS=3                # prior Q&A pairs replayed for follow-ups (0 = off)
CHAT_MAX_COST_USD=0.50              # owner/service chat runs
FREE_CHAT_MAX_COST_USD=0.10         # per-question budget on Free
PRO_CHAT_MAX_COST_USD=0.30          # per-question budget on Pro
DIGEST_MAX_ITERATIONS=25
DIGEST_MAX_COST_USD=1.50
MACRO_MAX_ITERATIONS=30
MACRO_MAX_COST_USD=2.00
MAX_TOOL_OUTPUT_TOKENS=6000
TOOL_TIMEOUT_SECONDS=10

# --- Plan gating (Free vs Pro limits) ----------------------------------------

TRIAL_DAYS=7                        # no-card Pro trial on signup; 0 disables
# Question quotas are the visible limit (rolling windows); the monthly cost
# caps are a fair-use backstop sized so the full quota fits with margin.
FREE_WEEKLY_CHAT_LIMIT=3            # questions per rolling 7 days
PRO_DAILY_CHAT_LIMIT=10             # questions per rolling 24 hours
FREE_MONTHLY_COST_CAP_USD=1.50
PRO_MONTHLY_COST_CAP_USD=9.00
FREE_MAX_DIGEST_HOLDINGS=3          # watchlist cap on Free tier

# --- Scheduling --------------------------------------------------------------

DIGEST_CRON=0 9 * * 1-5             # weekday morning digest (America/Toronto)
TZ=America/Toronto
MACRO_SCAN_INTERVAL_MINUTES=0         # set e.g. 60 to enable in-process macro scans

# --- Daily holding-news refresh (news feed) ------------------------------------

NEWS_REFRESH_CRON=50 8 * * *        # 7 days/week, before DIGEST_CRON; empty = off
#NEWS_MAX_PER_TICKER=2              # articles persisted per ticker per run
#NEWS_MIN_SALIENCE=0.5              # keep if signal != neutral OR salience >= this
#NEWS_REFRESH_MAX_COST_USD=0.05     # cap on Haiku importance calls per run

# --- Price-anomaly alerts (statistical detectors, model-free) -----------------

ANOMALY_SCAN_CRON=                  # e.g. "30 16 * * 1-5" (after close); empty = off
# Thresholds operate on daily log returns; defaults calibrated with
# scripts/calibrate_detectors.py — re-run it before changing these.
#ANOMALY_ZSCORE_K=3.0
#ANOMALY_CUSUM_H=8.0
#ANOMALY_COOLDOWN_DAYS=3
ANOMALY_BENCHMARK_TICKER=           # e.g. XIU.TO or SPY to enable the divergence detector

# --- Per-ticker fundamentals (dashboard metrics + stock detail pages) ---------

FUNDAMENTALS_REFRESH_CRON=30 18 * * 1-5  # nightly pre-warm of held tickers; empty = lazy only
#FUNDAMENTALS_TTL_HOURS=24          # refresh rows older than this on read (stale-while-revalidate)
#FUNDAMENTALS_ERROR_TTL_HOURS=1     # retry window for tickers Yahoo couldn't serve
#FUNDAMENTALS_BETA_BENCHMARK=^GSPC  # benchmark for the computed-beta fallback

# --- Scheduled-job health (/health "jobs" staleness) ---------------------------

#JOB_DEGRADED_FACTOR=3.0            # interval jobs: missed intervals before degraded
#JOB_OFFLINE_FACTOR=10.0            # ... before offline
#DIGEST_MISFIRE_GRACE_SECONDS=3600  # late cron fire still runs within this window

# --- News (optional — yfinance fallback if empty) ----------------------------

FINNHUB_API_KEY=

# --- Stripe billing (Pro upgrades) — https://dashboard.stripe.com ------------
# All of SECRET_KEY, PRICE_PRO_MONTHLY, and PUBLIC_BASE_URL must be set for
# billing to be enabled; otherwise the UI keeps its "coming soon" copy.

STRIPE_SECRET_KEY=                  # sk_live_... (or sk_test_... locally)
STRIPE_WEBHOOK_SECRET=              # whsec_... for POST /webhooks/stripe
STRIPE_PRICE_PRO_MONTHLY=           # price_... ($15/mo USD)
STRIPE_PRICE_PRO_ANNUAL=            # price_... ($120/yr USD); empty hides yearly
STRIPE_AUTOMATIC_TAX=false          # enable once GST/HST-registered (Stripe Tax)

# --- SnapTrade (Wealthsimple sync) — https://dashboard.snaptrade.com --------

SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
# Personal dashboard keys: leave USER_ID/SECRET empty (auto mode, owner only).
# Commercial keys: per-user secrets stored encrypted in DB.
SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=
SNAPTRADE_AUTH_MODE=auto            # auto | personal | commercial
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BROKER_SECRETS_KEY=

# --- Multi-channel delivery (optional) ---------------------------------------
# Dispatcher drains outbound_messages every N seconds. 0 disables it.

DELIVERY_INTERVAL_SECONDS=30
DELIVERY_MAX_ATTEMPTS=5
# Public origin (no trailing slash): Twilio webhook validation and og:url /
# og:image on marketing pages (falls back to https://cirvia.ca when unset).
PUBLIC_BASE_URL=                    # e.g. https://app.example.com

# Twilio SMS (all three required for the sms channel)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=                   # E.164, e.g. +14165550100
# Point inbound SMS webhook at $PUBLIC_BASE_URL/webhooks/twilio/sms

# Resend email (both required for the email channel)
RESEND_API_KEY=
EMAIL_FROM=                           # e.g. "Cirvia <digest@yourdomain.com>"
# HMAC key for signed email unsubscribe links (CASL). Long random string;
# falls back to API_TOKEN when unset.
UNSUBSCRIBE_SECRET=

# Discord uses per-user webhook URLs (no env vars). Configure in /app onboarding.

# --- Portfolio Deep Dive (multi-agent research; Pro-only) ---------------------
# Overall USD cap per run; per-stage budgets live in code. Weekly limit is a
# rolling 7-day quota per Pro user. DEEP_DIVE_CRON="" keeps runs manual-only.
DEEP_DIVE_MAX_COST_USD=1.00
DEEP_DIVE_WEEKLY_LIMIT=2
DEEP_DIVE_CRON=

# --- Semantic memory (pgvector + Voyage embeddings; optional) -----------------
# Unset VOYAGE_API_KEY = feature off (no ingestion, no recall_memory chat tool).
# Requires migration 019 (pgvector). Backfill: python scripts/backfill_memory.py
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3.5-lite
MEMORY_BACKFILL_MAX_COST_USD=1.00
